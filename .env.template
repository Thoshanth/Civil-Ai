# ========================================
# CivilAI Environment Variables Template
# ========================================
# Copy this file and fill in your actual values
# DO NOT commit files with real credentials!

# ========================================
# 1. DATABASE (Neon.tech)
# ========================================
# Get from: https://neon.tech
# Create project → Copy connection string
DB_HOST=your-project.neon.tech:5432
DB_USERNAME=your_username
DB_PASSWORD=your_password
DB_NAME=neondb
DB_SSL_MODE=require

# ========================================
# 2. FILE STORAGE (Cloudflare R2)
# ========================================
# Get from: https://cloudflare.com
# Dashboard → R2 → Create bucket → API tokens
MINIO_ENDPOINT=https://your-account.r2.cloudflarestorage.com
MINIO_ACCESS_KEY=your_r2_access_key_id
MINIO_SECRET_KEY=your_r2_secret_access_key
MINIO_BUCKET=civilai-files

# ========================================
# 3. AI SERVICE URLS
# ========================================
# Update after deploying AI Gateway to Render
AI_SERVICE_URL=https://civilai-gateway.onrender.com
VITE_API_BASE_URL=https://civilai-backend.onrender.com/api

# ========================================
# 4. LLM API KEYS
# ========================================
# Groq (Primary LLM): https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# Google Gemini (Fallback + Vision): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy_your_gemini_api_key_here

# HuggingFace (Optional Fallback): https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_huggingface_token_here

# ========================================
# 5. JWT CONFIGURATION
# ========================================
# Generate a random 32+ character string
# Example: openssl rand -base64 32
JWT_SECRET=change_this_to_a_random_32_character_string_minimum_length

# ========================================
# 6. EMAIL CONFIGURATION (Optional)
# ========================================
# For OTP verification emails
# Gmail: Use App Password (not regular password)
# https://myaccount.google.com/apppasswords
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587

# ========================================
# 7. SPRING CONFIGURATION
# ========================================
SPRING_PROFILES_ACTIVE=prod

# ========================================
# 8. PYTHON VERSION
# ========================================
PYTHON_VERSION=3.11

# ========================================
# DEPLOYMENT CHECKLIST
# ========================================
# [ ] Created Neon.tech database
# [ ] Created Cloudflare R2 bucket
# [ ] Got Groq API key
# [ ] Got Gemini API key
# [ ] Got HuggingFace token (optional)
# [ ] Generated JWT secret
# [ ] Configured email (optional)
# [ ] Deployed AI Gateway to Render
# [ ] Deployed Backend to Render
# [ ] Deployed Frontend to Vercel
# [ ] Updated CORS in SecurityConfig.java
# [ ] Tested registration
# [ ] Tested login
# [ ] Tested file upload
# [ ] Tested analysis
