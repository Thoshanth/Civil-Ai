# CivilAI Backend Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# DATABASE (PostgreSQL - Neon.tech)
# ============================================
DB_HOST=your-project.neon.tech:5432
DB_USERNAME=your_username
DB_PASSWORD=your_password
DB_SSL_MODE=require

# ============================================
# MINIO (File Storage)
# ============================================
# For local development with Docker:
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=civilai-files

# For production (Railway/MinIO Cloud):
# MINIO_ENDPOINT=https://your-minio-instance.railway.app
# MINIO_ACCESS_KEY=your_access_key
# MINIO_SECRET_KEY=your_secret_key

# ============================================
# AI SERVICE (FastAPI Gateway)
# ============================================
# Local development:
AI_SERVICE_URL=http://localhost:8000

# Production:
# AI_SERVICE_URL=https://your-ai-service.onrender.com

# ============================================
# JWT (Authentication)
# ============================================
# Generate a secure random string (minimum 32 characters)
# You can use: openssl rand -base64 32
JWT_SECRET=change_this_to_a_secure_random_string_minimum_32_characters

# ============================================
# EMAIL (Gmail SMTP)
# ============================================
# For Gmail, use App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password

# ============================================
# SERVER (Optional)
# ============================================
# PORT=8080

# ============================================
# LOGGING (Optional)
# ============================================
# LOG_LEVEL=INFO
